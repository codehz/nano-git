{
  "name": "nano-git",
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./transport": "./src/transport/index.ts",
    "./odb": "./src/odb/index.ts",
    "./refs": "./src/refs/index.ts",
    "./core": "./src/core/index.ts",
    "./objects": "./src/objects/index.ts",
    "./repository": "./src/repository/index.ts"
  },
  "scripts": {
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md}": [
      "oxfmt"
    ]
  }
}
